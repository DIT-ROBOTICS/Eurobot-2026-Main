<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================= -->
<!-- test for TAKE/PUT publisher -->
<!-- ============================================= -->
<root BTCPP_format="4">
    
    <!-- ============================================= -->
    <!-- TAKE SubTree: Go to collection point and take -->
    <!-- ============================================= -->
    <BehaviorTree ID="TakeSubTree">
        <Sequence>
            <!-- Dock to collection point -->
            <OnDockAction
                targetPoseIdx="{target_idx}"
                targetPoseSideIdx="{target_side}"
                targetDirection="{target_dir}"
                dock_type="dock_y_loose_linearBoost"
                isPureDocking="false"
                finish_pose="{dock_result}"/>
            
            <!-- Publish TAKE command and wait for completion -->
            <TakePublisher_white
                targetPoseSideIdx="{target_side}"
                targetPoseIdx="{target_idx}"
                timeout_ms="2000"/>   <!-- test for callback -->
            <FieldUpdater/>
            <!-- <Sleep msec="2000"/> -->
        </Sequence>
    </BehaviorTree>

    <!-- ============================================= -->
    <!-- FLIP SubTree: Flip the hazelnut               -->
    <!-- ============================================= -->
    <BehaviorTree ID="FlipSubTree">
        <Sequence>
            <!-- Publish FLIP command and wait for completion -->
            <FlipPublisher_white
                targetPoseSideIdx="{target_side}"
                targetPoseIdx="{target_idx}"
                timeout_ms="1000"/>
        </Sequence>
    </BehaviorTree>
    
    <!-- ============================================= -->
    <!-- PUT SubTree: Go to pantry point and put -->
    <!-- ============================================= -->
    <BehaviorTree ID="PutSubTree">
        <Sequence>
            <!-- Flip and Dock in parallel: FlipPublisher waits for isDocking signal -->
            <Parallel success_count="2" failure_count="1">
                <OnDockAction
                    targetPoseIdx="{target_idx}"
                    targetPoseSideIdx="{target_side}"
                    targetDirection="{target_dir}"
                    dock_type="dock_y_loose_linearBoost"
                    isPureDocking="false"
                    finish_pose="{dock_result}"/>
                <FlipPublisher_white
                    targetPoseIdx="{target_idx}"
                    targetPoseSideIdx="{target_side}"
                    timeout_ms="1000"/>
            </Parallel>
            
            <!-- Publish PUT command and wait for completion -->
            <PutPublisher
                targetPoseSideIdx="{target_side}"
                targetPoseIdx="{target_idx}"
                timeout_ms="2500"/>   <!-- test for callback -->
            <FieldUpdater/>
            <Sleep msec="500"/>
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="CursorSubTree">
        <Sequence>
            <Parallel success_count="2" failure_count="1">
                <OnDockAction
                    targetPoseIdx="{target_idx}"
                    targetPoseSideIdx="{target_side}"
                    targetDirection="{target_dir}"
                    dock_type="dock_y_loose_linearBoost"
                    isPureDocking="false"
                    finish_pose="{dock_result}"/>
                <CursorPublisher
                    arms="left"
                    targetPoseIdx="{target_idx}"/>
            </Parallel>
            <Sleep msec="500"/>
        </Sequence>
    </BehaviorTree>
    
    <!-- ============================================= -->
    <!-- Main Tree: Complete collection cycle -->
